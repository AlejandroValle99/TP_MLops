# PostgreSQL
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change_me
POSTGRES_DB=airflow_db

# MinIO (S3-compatible artifact store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

# Airflow  — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# API — model serving
MODEL_NAME=stroke-model
MODEL_ALIAS=champion


MUTATION_SAMPLE_RATE=0.80
MUTATION_NOISE_STD=0.03
